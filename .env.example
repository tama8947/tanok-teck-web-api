# ──────────────────────────────
# Tanok Web API — Environment Variables
# Copy to .env and fill in the values.
# ──────────────────────────────

# ── Server ─────────────────────
PORT=8080
GIN_MODE=debug
COOKIE_DOMAIN=tanok-tech.com
BASE_URL=https://tanok-web-api.tanok-tech.com
CORS_ALLOWED_ORIGINS=https://tanok-tech.com,https://www.tanok-tech.com

# ── Database ───────────────────
DATABASE_URL=postgres://user:pass@host:5432/tanok?sslmode=disable

# ── Redis ──────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────
JWT_SECRET=
API_TOKEN=
CRON_SECRET=

# ── Email (Resend) ─────────────
RESEND_API_KEY=

# ── AI ─────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.5-highspeed

# ── Search ─────────────────────
BRAVE_API_KEY=

# ── Image Storage (Cloudflare R2) ──
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tanok-web-images
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Daily Posts ────────────────
DAILY_POSTS_AUTHOR_ID=
